{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "battle-websocket-event.schema.json",
  "title": "BattleWebSocketEvent",
  "oneOf": [
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "const": "battle.ping"
        },
        "requestId": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "payload"],
      "properties": {
        "type": {
          "const": "battle.submit_action"
        },
        "requestId": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "required": [
            "battleSessionId",
            "playerId",
            "turnNumber",
            "actionId",
            "gestureSequence",
            "submittedAt"
          ],
          "properties": {
            "battleSessionId": {
              "type": "string"
            },
            "playerId": {
              "type": "string"
            },
            "turnNumber": {
              "type": "integer",
              "minimum": 1
            },
            "actionId": {
              "type": "string",
              "minLength": 1
            },
            "gestureSequence": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "submittedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "payload"],
      "properties": {
        "type": {
          "const": "battle.pong"
        },
        "requestId": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "required": ["ok"],
          "properties": {
            "ok": {
              "type": "boolean"
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "payload"],
      "properties": {
        "type": {
          "const": "battle.action_result"
        },
        "requestId": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "required": ["battleSessionId", "turnNumber", "actionId", "status"],
          "properties": {
            "battleSessionId": {
              "type": "string"
            },
            "turnNumber": {
              "type": "integer"
            },
            "actionId": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": ["ACCEPTED", "REJECTED"]
            },
            "reason": {
              "type": "string"
            },
            "battle": {
              "type": ["object", "null"]
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "payload"],
      "properties": {
        "type": {
          "const": "battle.error"
        },
        "requestId": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    }
  ]
}
